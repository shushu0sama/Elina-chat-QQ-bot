# NoneBot2 + OneBot v11 connection
ONEBOT_WS_URLS=["ws://127.0.0.1:18080/onebot/v11/ws"]
HOST=127.0.0.1
PORT=18080

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# Memory
MEMORY_DB_PATH=./nonebot_plugin_personal_companion/data/memory.db
MAX_RECENT_MESSAGES=30
SUMMARY_TRIGGER_COUNT=20
MEMORY_INJECTION_CAP_TOKENS=2000
AUTO_EXTRACT_INTERVAL=10

# Proactive chat
PROACTIVE_ENABLED=true
PROACTIVE_ALLOW_USERS=   # QQ号, 逗号分隔, 留空=所有用户
PROACTIVE_INTERVAL_MINUTES=30
PROACTIVE_COOLDOWN_MINUTES=60
PROACTIVE_ACTIVE_HOURS_START=8
PROACTIVE_ACTIVE_HOURS_END=24

# Content push (Bilibili)
CONTENT_PUSH_ENABLED=true
CONTENT_PUSH_INTERVAL_HOURS=6
CONTENT_PUSH_BILI_CATEGORIES=0,36,188
CONTENT_PUSH_MAX_PER_PUSH=1

# Web search (function calling — bot searches when uncertain)
WEB_SEARCH_ENABLED=true
WEB_SEARCH_BACKEND=bing   # bing | duckduckgo (bing works in China)
WEB_SEARCH_MAX_RESULTS=5

# Bot identity
BOT_NICKNAME=艾琳娜
